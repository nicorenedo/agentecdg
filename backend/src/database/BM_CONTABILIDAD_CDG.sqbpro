e="92"/><column index="3" value="193"/><column index="4" value="103"/><column index="6" value="165"/><column index="7" value="168"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="PRECIO_POR_PRODUCTO_STD" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="137"/><column index="2" value="101"/><column index="3" value="157"/><column index="4" value="41"/><column index="5" value="145"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="SQL 1*">DROP TABLE PRECIO_POR_PRODUCTO_STD;

-- Crear tabla PRECIO_POR_PRODUCTO_STD (Precios presupuestarios anuales)
CREATE TABLE PRECIO_POR_PRODUCTO_STD (
    SEGMENTO_ID INTEGER NOT NULL,
    PRODUCTO_ID TEXT NOT NULL,
    PRECIO_MANTENIMIENTO REAL NOT NULL,
    ANNO INTEGER NOT NULL DEFAULT 2025,
    FECHA_ACTUALIZACION DATE NOT NULL DEFAULT '2025-01-01',
    PRIMARY KEY (SEGMENTO_ID, PRODUCTO_ID),
    FOREIGN KEY (SEGMENTO_ID) REFERENCES MAESTRO_SEGMENTOS(SEGMENTO_ID),
    FOREIGN KEY (PRODUCTO_ID) REFERENCES MAESTRO_PRODUCTOS(PRODUCTO_ID)
);

-- Insertar registros en PRECIO_POR_PRODUCTO_STD (Precios presupuestarios 2025)
INSERT INTO PRECIO_POR_PRODUCTO_STD (SEGMENTO_ID, PRODUCTO_ID, PRECIO_MANTENIMIENTO) VALUES 
    -- PRÉSTAMOS HIPOTECARIOS (100100100100)
    ('N10101', '100100100100', -230.00),  -- Banca Minorista
    ('N10102', '100100100100', -400.00),  -- Banca Privada  
    ('N10103', '100100100100', -420.00),  -- Banca de Empresas
    ('N10104', '100100100100', -140.00),  -- Banca Personal
    -- No hay precio para Segmento N20301 (Fondos) en préstamos hipotecarios
    
    -- DEPÓSITOS A PLAZO FIJO (400200100100)
    ('N10101', '400200100100', -230.00),  -- Banca Minorista
    ('N10102', '400200100100', -520.00),  -- Banca Privada
    ('N10103', '400200100100', -390.00),  -- Banca de Empresas
    ('N10104', '400200100100', -230.00),  -- Banca Personal
    ('N20301', '400200100100', -180.00),  -- Fondos
    
    -- FONDOS BANCA MARCH (600100300300) - Estimaciones realistas
    ('N10101', '600100300300', -150.00),  -- Banca Minorista
    ('N10102', '600100300300', -280.00),  -- Banca Privada
    ('N10103', '600100300300', -320.00),  -- Banca de Empresas
    ('N10104', '600100300300', -120.00),  -- Banca Personal
    ('N20301', '600100300300', -90.00);   -- Fondos

-- Actualizar precios estándar con valores más realistas
UPDATE PRECIO_POR_PRODUCTO_STD SET PRECIO_MANTENIMIENTO = 
CASE 
    -- PRÉSTAMOS HIPOTECARIOS (base ~€-1,300)
    WHEN SEGMENTO_ID = 'N10101' AND PRODUCTO_ID = '100100100100' THEN -1250.00  -- Banca Minorista
    WHEN SEGMENTO_ID = 'N10102' AND PRODUCTO_ID = '100100100100' THEN -1320.00  -- Banca Privada
    WHEN SEGMENTO_ID = 'N10103' AND PRODUCTO_ID = '100100100100' THEN -1280.00  -- Banca de Empresas
    WHEN SEGMENTO_ID = 'N10104' AND PRODUCTO_ID = '100100100100' THEN -1200.00  -- Banca Personal
    
    -- DEPÓSITOS A PLAZO FIJO (base ~€-1,250)
    WHEN SEGMENTO_ID = 'N10101' AND PRODUCTO_ID = '400200100100' THEN -1240.00  -- Banca Minorista
    WHEN SEGMENTO_ID = 'N10102' AND PRODUCTO_ID = '400200100100' THEN -1300.00  -- Banca Privada
    WHEN SEGMENTO_ID = 'N10103' AND PRODUCTO_ID = '400200100100' THEN -1270.00  -- Banca de Empresas
    WHEN SEGMENTO_ID = 'N10104' AND PRODUCTO_ID = '400200100100' THEN -1220.00  -- Banca Personal
    WHEN SEGMENTO_ID = 'N20301' AND PRODUCTO_ID = '400200100100' THEN -1180.00  -- Fondos
    
    -- FONDOS BANCA MARCH (base ~€-1,200)
    WHEN SEGMENTO_ID = 'N10101' AND PRODUCTO_ID = '600100300300' THEN -1230.00  -- Banca Minorista
    WHEN SEGMENTO_ID = 'N10102' AND PRODUCTO_ID = '600100300300' THEN -1290.00  -- Banca Privada
    WHEN SEGMENTO_ID = 'N10103' AND PRODUCTO_ID = '600100300300' THEN -1260.00  -- Banca de Empresas
    WHEN SEGMENTO_ID = 'N10104' AND PRODUCTO_ID = '600100300300' THEN -1190.00  -- Banca Personal
    WHEN SEGMENTO_ID = 'N20301' AND PRODUCTO_ID = '600100300300' THEN -1160.00  -- Fondos
    
    ELSE PRECIO_MANTENIMIENTO  -- Mantener valor original si no coincide
END;

-- Añadir precio para Fondos - Préstamos Hipotecarios (faltaba)
INSERT OR REPLACE INTO PRECIO_POR_PRODUCTO_STD (SEGMENTO_ID, PRODUCTO_ID, PRECIO_MANTENIMIENTO) 
VALUES ('N20301', '100100100100', -1170.00);

