SELECT 
    'Contratos_totales' as TIPO,
    COUNT(*) as CANTIDAD
FROM MAESTRO_CONTRATOS

UNION ALL

SELECT 
    'Contratos_centros_1_5' as TIPO,
    COUNT(*) as CANTIDAD  
FROM MAESTRO_CONTRATOS
WHERE CENTRO_CONTABLE BETWEEN 1 AND 5

UNION ALL

SELECT 
    'Contratos_hasta_octubre' as TIPO,
    COUNT(*) as CANTIDAD
FROM MAESTRO_CONTRATOS
WHERE FECHA_ALTA &lt;= '2025-10-01'
  AND CENTRO_CONTABLE BETWEEN 1 AND 5

UNION ALL

SELECT 
    'Contratos_con_gestor_valido' as TIPO,
    COUNT(*) as CANTIDAD
FROM MAESTRO_CONTRATOS c
JOIN MAESTRO_GESTORES g ON c.GESTOR_ID = g.GESTOR_ID
WHERE c.FECHA_ALTA &lt;= '2025-10-01'
  AND c.CENTRO_CONTABLE BETWEEN 1 AND 5;
  
  
  SELECT SUM(IMPORTE) FROM GASTOS_CENTRO WHERE FECHA = '2025-10-01';
SELECT SUM(ABS(IMPORTE)) FROM MOVIMIENTOS_CONTRATOS WHERE FECHA = '2025-10-01' AND CONTRATO_ID IS NULL AND IMPORTE &lt; 0;
