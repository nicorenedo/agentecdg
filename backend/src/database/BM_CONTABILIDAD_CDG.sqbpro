lumn_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="MAESTRO_PRODUCTOS" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="101"/><column index="2" value="241"/><column index="3" value="87"/><column index="4" value="58"/><column index="5" value="48"/><column index="6" value="84"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="MAESTRO_SEGMENTOS" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="91"/><column index="2" value="140"/><column index="3" value="84"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="MOVIMIENTOS_CONTRATOS" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="106"/><column index="2" value="84"/><column index="3" value="85"/><column index="4" value="93"/><column index="5" value="123"/><column index="6" value="76"/><column index="7" value="49"/><column index="8" value="78"/><column index="9" value="178"/><column index="10" value="300"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="PRECIO_POR_PRODUCTO_STD" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="94"/><column index="2" value="101"/><column index="3" value="157"/><column index="4" value="41"/><column index="5" value="145"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="SQL 1">-- Ver inconsistencias actuales
SELECT 
    'INCONSISTENCIA' as tipo,
    mc.CONTRATO_ID,
    mc.CLIENTE_ID,
    mcl.NOMBRE_CLIENTE,
    mc.GESTOR_ID as gestor_en_contrato,
    mcl.GESTOR_ID as gestor_del_cliente,
    'CONTRATO DEBE CAMBIAR A ' || mcl.GESTOR_ID as accion_requerida
FROM MAESTRO_CONTRATOS mc
JOIN MAESTRO_CLIENTES mcl ON mc.CLIENTE_ID = mcl.CLIENTE_ID
WHERE mc.GESTOR_ID != mcl.GESTOR_ID
ORDER BY mc.CLIENTE_ID, mc.CONTRATO_ID
LIMIT 20;
</sql><current_tab id="0"/></tab_sql></sqlb_project>
